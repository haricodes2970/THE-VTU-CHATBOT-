# ════════════════════════════════════════════════════════════
#  VTU Smart Scheduler — Environment Variables
#  Copy this file to .env and fill in your real values
# ════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────
APP_NAME="VTU Smart Scheduler"
APP_ENV=development           # development | production
APP_PORT=8000
SECRET_KEY=change-this-to-a-random-32-char-string

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=vtu_scheduler
POSTGRES_USER=vtu_user
POSTGRES_PASSWORD=vtu_password
DATABASE_URL=postgresql://vtu_user:vtu_password@localhost:5432/vtu_scheduler

# ── Groq (LLM) ───────────────────────────────────────────────
# Get free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192     # llama3-8b-8192 | llama3-70b-8192 | mixtral-8x7b-32768

# ── Pinecone (Vector DB) ──────────────────────────────────────
# Get free key at: https://app.pinecone.io
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=vtu-circulars
PINECONE_DIMENSION=384        # matches all-MiniLM-L6-v2 embedding size

# ── VTU Scraper ───────────────────────────────────────────────
VTU_BASE_URL=https://vtu.ac.in
VTU_CIRCULARS_URL=https://vtu.ac.in/circulars
SCRAPER_INTERVAL_HOURS=6      # how often to check for new circulars
PDF_DOWNLOAD_PATH=./data/pdfs

# ── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
EMAIL_FROM=VTU Scheduler <your_email@gmail.com>

# ── Telegram Bot ─────────────────────────────────────────────
# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Redis (optional — for caching) ───────────────────────────
REDIS_URL=redis://localhost:6379
